{
  "name": "cs-baoyan-ddl",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "predev": "tsx scripts/build-logos.ts",
    "dev": "vite",
    "prebuild": "tsx scripts/build-logos.ts",
    "build": "vite build --mode production",
    "prebuild:e2e": "tsx scripts/build-logos.ts",
    "build:e2e": "rm -rf dist-e2e && vite build --mode e2e",
    "preview": "vite preview --port 4173",
    "test": "tsx --test --test-concurrency=1 tests/*.test.ts",
    "test:unit": "tsx --test --test-concurrency=1 tests/*.test.ts",
    "snapshot:import": "tsx scripts/snapshot/import-scouting-data.ts",
    "snapshot:diff": "tsx scripts/snapshot/diff-snapshots.ts",
    "snapshot:approve": "tsx scripts/snapshot/approve-snapshot.ts",
    "snapshot:validate": "tsx scripts/snapshot/validate-current.ts",
    "snapshot:check-freshness": "tsx scripts/snapshot/check-freshness.ts",
    "check:public": "bash scripts/check-public.sh",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:e2e-isolation": "tsx scripts/check-e2e-isolation.ts",
    "test:e2e": "pnpm run build && pnpm run build:e2e && pnpm run check:e2e-isolation && playwright test"
  },
  "dependencies": {
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
